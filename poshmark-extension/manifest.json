{
  "manifest_version": 3,
  "name": "Elister Fast Automator",
  "version": "1.0.0",
  "description": "Supercharge your Poshmark listing, sharing, and management tasks using high-speed direct API automation.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "*://*.poshmark.com/*",
    "*://*.poshmark.ca/*",
    "*://*.poshmark.co.uk/*",
    "*://*.poshmark.com.au/*",
    "*://app.elister.ai/*",
    "*://localhost/*",
    "*://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.poshmark.com/*",
        "*://*.poshmark.ca/*",
        "*://*.poshmark.co.uk/*",
        "*://*.poshmark.com.au/*",
        "*://app.elister.ai/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.poshmark.com/*",
        "*://*.poshmark.ca/*",
        "*://*.poshmark.co.uk/*",
        "*://*.poshmark.com.au/*"
      ],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
