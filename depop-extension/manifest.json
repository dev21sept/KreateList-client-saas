{
  "manifest_version": 3,
  "name": "Elister Depop Fast Automator",
  "version": "1.0.0",
  "description": "Supercharge your Depop listing, sharing, and management tasks using high-speed direct API automation.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.depop.com/*",
    "*://*.elister.ai/*",
    "*://*.amazonaws.com/*",
    "*://app.elister.ai/*",
    "*://localhost/*",
    "*://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.depop.com/*",
        "*://app.elister.ai/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.depop.com/*"
      ],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
